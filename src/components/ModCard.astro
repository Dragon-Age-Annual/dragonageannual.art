---
import type { ImageMetadata } from "astro";
import type { SocialLinksData } from "@fujocoded/zod-transform-socials";
import { Icon } from "astro-icon/components";

interface Props {
  order: number;
  name: string;
  avatar: ImageMetadata;
  roles: Array<string>;
  links: SocialLinksData;
}

const props = Astro.props;

const altText: string = `${props.name}'s Avatar`;
---

<article
  class="w-prose space-content bg-daa-white/10 border border-gold mb-4 flex max-w-[90vw] flex-col rounded-xl px-6lg:w-full"
>
  <div class="grid auto-cols-max grid-flow-col gap-x-6 gap-y-1 prose-daa">
    <div
      class="fit-content align-center bg-teal-mid row-span-3 self-center rounded-full"
    >
      <img src={props.avatar.src} alt={altText} class="w-24 rounded-full" />
    </div>
    <h3 class="font-display!">{props.name}</h3>

    <ul
      class="list-style-none flex w-[75%] flex-row flex-wrap capitalize xl:w-full xl:flex-nowrap"
    >
      {
        props.roles.map((role, index) => (
          <li class="inline-block w-fit text-wrap wrap-break-word font-mono text-sm">
            {index - (props.roles.length - 1) ? role + ",\xa0" : role}
          </li>
        ))
      }
    </ul>
    <ul
      class:list={{ hidden: props.links.length == 0 }}
      class="list-type-none flex flex-row gap-2"
    >
      {
        props.links.map((link) => (
          <li class="w-6">
            <a href={link.url}>
              {link.icon ? (
                <>
                  <Icon name={link.icon} title={link.platform} />
                </>
              ) : (
                <>
                  <Icon
                    name={"lucide:home"}
                    title={`${props.name}'s website`}
                  />
                </>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
  <div
    class="space-content border-pink scrollbar-thin scrollbar-gold shadow-arcane-800 h-[200px] overflow-y-scroll border-t px-5 pt-5 shadow-[inset_0_10px_9px_-10px]"
  >
    <slot />
  </div>
</article>
