---
import type { ImageMetadata } from "astro";

interface Props {
  year: number;
  title: string;
  theme: string;
  charityName: string;
  charityLink: string;
  cover: ImageMetadata;
  coverAlt: string;
  amountUS: number | string;
  amountUK: number | string;
}

const props = Astro.props;

const dollars = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: "USD",
});

const pounds = new Intl.NumberFormat("en-UK", {
  style: "currency",
  currency: "GBP",
});

// Convert to numbers first
const amountUSNum = Number(props.amountUS);
const amountUKNum = Number(props.amountUK);

// Fallback logic
const donationUS = Number.isNaN(amountUSNum)
  ? "$ TBD"
  : dollars.format(amountUSNum);

const donationUK = Number.isNaN(amountUKNum)
  ? "£ TBD"
  : pounds.format(amountUKNum);
---


<article class="w-prose relative min-h-full flex-col rounded-lg md:w-[360px] hover:border hover:border-pink">
  <div
    class="bg-arcane-800 border-gold flex h-64 rounded-t-xl border-b-8 px-6 py-12"
  >
    <img
      src={props.cover.src}
      alt={props.coverAlt}
      class="self-center lg:w-[360px]"
    />
  </div>
  <div class="flex h-64">
    <ul class="list-style-none! pb-4 self-center ml-4!">
      <li>
        <strong>Theme:</strong>
        {props.theme}
      </li>
      <li>
        <strong>Charity:</strong>
        <a href={props.charityLink}>{props.charityName}</a>
      </li>
      <li>
        <strong>Donation:</strong>
        {donationUS} / {donationUK}
      </li>
    </ul>
  </div>
</article>
